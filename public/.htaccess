# Enable rewriting engine
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Allow access to Next.js static metadata files starting with double underscores
    RewriteCond %{REQUEST_URI} ^/__next [OR]
    RewriteCond %{REQUEST_URI} /__next
    RewriteRule ^ - [L]
</IfModule>

# Prevent directory listings
Options -Indexes

# ─── Cache Control ────────────────────────────────────────────────────────────

<IfModule mod_headers.c>

    # 1. Hashed static assets (JS, CSS, fonts, images inside _next/static)
    #    These filenames change on every build, so it is safe to cache forever.
    <FilesMatch "\.(js|css|woff2?|ttf|eot|otf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # 2. HTML pages — must NEVER be served stale.
    #    no-store forces the browser to re-fetch every time.
    <FilesMatch "\.html$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    # 3. Images in /public (not content-hashed) — revalidate after 1 day.
    <FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|avif|ico)$">
        Header set Cache-Control "public, max-age=86400, must-revalidate"
    </FilesMatch>

</IfModule>
